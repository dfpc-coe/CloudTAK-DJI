        "babel-preset-vite": "^1.1.3",
        "eslint": "^10.2.1",
        "eslint-plugin-vue": "^10.9.0",
        "globals": "^17.5.0",
        "openapi-typescript": "^7.13.0",
        "sass-embedded": "^1.99.0",
